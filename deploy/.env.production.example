# Business360 Production Environment
# Copy to deploy/.env.production and fill in all values
# NEVER commit .env.production to git

# App
NODE_ENV=production
PORT=4000

# Public URLs  (set these to your actual Cloudflare domains)
WEB_URL=https://app.YOUR_DOMAIN.com
FRONTEND_URL=https://app.YOUR_DOMAIN.com
API_URL=https://api.YOUR_DOMAIN.com

# PostgreSQL (used by Docker Compose)
POSTGRES_DB=business360
POSTGRES_USER=b360
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# Prisma / API database URL (points to the postgres service inside Docker)
DATABASE_URL=postgresql://b360:CHANGE_ME_strong_password@postgres:5432/business360?schema=public

# Auth — generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_at_least_64_random_hex_chars

# Stripe (leave blank if not used)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_YEARLY=price_...

# Email — Resend (https://resend.com)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@YOUR_DOMAIN.com

# Redis (optional, used for sessions/cache)
REDIS_URL=redis://redis:6379
