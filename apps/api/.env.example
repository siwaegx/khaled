DATABASE_URL="postgresql://postgres:password@localhost:5432/business360"
JWT_SECRET="change-this-in-production-use-a-long-random-string"
PORT=4000
NODE_ENV=development
WEB_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"
API_URL="http://localhost:4000"
# Email (Resend) — get your key at https://resend.com
RESEND_API_KEY=re_your_key_here
RESEND_FROM="Business360 <noreply@yourdomain.com>"
# Optional — Redis caching (ioredis)
# REDIS_URL=redis://localhost:6379

# Optional — OAuth (Google)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional — OAuth (GitHub)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Phase 3: tenant provisioning — uses DATABASE_URL credentials to create per-org databases
# TENANT_DATABASE_URL is set dynamically at runtime per organization, not needed here
